{
  "expo": {
    "name": "Tokrah",
    "slug": "tokrah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tokrah",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.outsiderstosociety.tokrah",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby users and improve matching.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to improve location-based features.",
        "NSLocationAlwaysUsageDescription": "This app uses your location to improve location-based features.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.outsiderstosociety.tokrah"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to show you nearby users.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to show you nearby users."
        }
      ],
      "expo-background-task",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "EXPO_PUBLIC_SUPABASE_URL": "https://smvgctdqokjjzjvbuxnc.supabase.co",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_1cLKHcOUtBYu0aDtMfPQWw_zW5ee7OS",
      "router": {},
      "eas": {
        "projectId": "5b076d8d-56f9-495f-8416-c2180eaea410"
      }
    },
    "owner": "outsiderstosociety"
  }
}
